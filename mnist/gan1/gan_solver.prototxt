# GAN Solver Configuration for MNIST - Generator Network
# Uses SGD optimizer optimized for GAN training (lower learning rate, high momentum)

net: "generator.prototxt"
test_iter: 100
test_interval: 10000

# Training parameters optimized for GAN
base_lr: 0.0002
lr_policy: "fixed"
momentum: 0.5
weight_decay: 0.0005

display: 100
max_iter: 10000
snapshot: 1000
snapshot_prefix: "gan_model"

# GPU configuration
device_id: 0
solver_mode: GPU

# Seed for reproducibility
random_seed: 1701
