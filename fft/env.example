# CUDA FFT Configuration

# ========== FFT Processing Options ==========
# Enable multi-GPU processing
FFT_USE_MULTI_GPU=0

# Input image file (PPM format)
# Leave unset to generate test image
# FFT_INPUT_FILE=input.ppm

# Output PPM filename
FFT_OUTPUT_FILE=fft_output.ppm

# Test image size (width and height)
FFT_TEST_IMAGE_SIZE=256

# Maximum number of GPUs to use
FFT_MAX_GPUS=1

# ========== Results Folder Configuration ==========
# Folder where results will be saved
FFT_RESULTS_FOLDER=./results

# Prefix for output filenames
# Example: with prefix "run1_" and output file "output.ppm"
# Results will be saved as: run1_output.ppm and run1_original_output.ppm
FFT_OUTPUT_PREFIX=

# ========== PPM to JPG Conversion Options ==========
# JPEG quality (1-100, higher = better quality, larger file)
JPG_QUALITY=85

# Delete original PPM files after conversion (true/false)
DELETE_PPM=false
